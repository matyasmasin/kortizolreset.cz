# ── Kortizol Reset — Apache/WEDOS konfigurace ──────────────────────────

# Vynutit HTTPS
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# www → bez www (kanonická verze je https://kortizolreset.cz/)
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# Vlastní chybová stránka
ErrorDocument 404 /404.html

# UTF-8
AddDefaultCharset UTF-8

# Cache statických souborů
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/x-icon "access plus 30 days"
  ExpiresByType application/manifest+json "access plus 7 days"
</IfModule>

# Komprese
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml application/manifest+json
</IfModule>

# Korektní MIME pro manifest
<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
</IfModule>
